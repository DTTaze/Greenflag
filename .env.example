# ═══════════════════════════════════════════════════════════
# TECHSOLVE 2025 — Staging Environment Configurations
# ═══════════════════════════════════════════════════════════

# ── App (NestJS Backend) ──────────────────────────────────
NODE_ENV=development
PORT=3030
SERVICE_NAME=greenflag-backend
ENABLE_CORS=true
ENABLE_SWAGGER=true
ENABLE_TRACING=true

# ── Database (PostgreSQL) ─────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=123
DB_SCHEMA=greenflag
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ── Redis (Cache + BullMQ) ────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth (JWT) ────────────────────────────────────────────
JWT_SECRET=supersecretjwtkeyforstaging2025
JWT_EXPIRATION=365d

# ── Google OAuth 2.0 ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/login?provider=GOOGLE

# ── Cloudinary (Media Upload) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=ptquanh
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP (Email) ──────────────────────────────────────────
SMTP_HOST=smtp.greenflag.id.vn
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USERNAME=support@greenflag.id.vn
SMTP_PASSWORD=
ADMIN_EMAILS=admin@greenflag.id.vn

# ── GHN Shipping API ─────────────────────────────────────
GHN_URL=https://dev-online-gateway.ghn.vn/shiip/public-api

# ── Audit / Observability ────────────────────────────────
AUDIT_WEBHOOK_URL=http://localhost:3030
PROMETHEUS_EXPORTER_PORT=8889
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Cloudflare Tunnel ─────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── Groq ────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL_NAME=

# ── Cloudflare R2 Storage Config ────────────────────────────────
R2_ACCOUNT_ID="Lấy dải mã hash nằm ở URL trình duyệt khi bạn ở trang chủ Cloudflare dash.cloudflare.com/<ACCOUNT_ID>"
R2_ACCESS_KEY_ID="Copy ở Bước 3"
R2_SECRET_ACCESS_KEY="Copy ở Bước 3"
R2_BUCKET_NAME="luakhoe-storage"
R2_PUBLIC_DOMAIN="https://pub-xxxxxx.r2.dev" # Copy ở Bước 4
{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon --exec ./node_modules/.bin/babel-node src/server.js",
    "migrate": "docker compose exec backend npx sequelize-cli db:migrate",
    "seed": "node src/seeders/index.js",
    "undoseed": "docker compose exec backend npx sequelize-cli db:seed:undo:all",
    "du": "docker compose down && docker compose up -d --build",
    "ddv": "docker compose down -v",
    "dbu": "docker exec mysql_container sh -c 'exec mysqldump -h localhost -u root --no-data techsolve25' > ./mysql_schema.sql",
    "db": "docker exec mysql_container sh -c \"mysqldump -h localhost -u root --no-data techsolve25\" > ./mysql_schema.sql",
    "rsr": "docker exec -it redis_container redis-cli FLUSHALL",
    "lint": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
